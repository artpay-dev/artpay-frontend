{
  "redirects": [
    {
      "source": "/",
      "destination": "https://gallerie.artpay.art",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/sso/:path*",
      "destination": "https://vendor.artpay.art/wp-json/artpay-sso/:path*"
    },
    { "source": "/(.*)", "destination": "/" }
  ]
}